<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>VEXRIVAL 3D</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Exo+2:wght@300;400;600&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
body{background:#000;overflow:hidden;font-family:'Exo 2',sans-serif}
#gameCanvas{position:fixed;top:0;left:0;z-index:1}
#hud{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:10}

/* CROSSHAIR */
#xhair{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:22px;height:22px}
#xhair::before,#xhair::after{content:'';position:absolute;background:rgba(255,255,255,0.9);box-shadow:0 0 4px rgba(100,200,255,0.8)}
#xhair::before{width:1.5px;height:100%;left:50%;transform:translateX(-50%)}
#xhair::after{height:1.5px;width:100%;top:50%;transform:translateY(-50%)}
#xhair-dot{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:3px;height:3px;background:#fff;border-radius:50%}

/* HEALTH */
#health-wrap{position:absolute;bottom:28px;left:28px}
#health-label{color:rgba(255,255,255,0.6);font-size:10px;letter-spacing:2px;text-transform:uppercase;margin-bottom:5px;font-family:'Orbitron',monospace}
#health-bar-track{width:220px;height:8px;background:rgba(255,255,255,0.1);border-radius:4px;overflow:hidden;border:1px solid rgba(255,255,255,0.15)}
#health-bar-fill{height:100%;width:100%;background:linear-gradient(90deg,#ff2244,#ff6677);border-radius:4px;transition:width .3s,background .5s}
#health-num{font-family:'Orbitron',monospace;font-size:28px;font-weight:700;color:#fff;text-shadow:0 0 12px rgba(255,50,80,0.8);margin-top:3px}
#armor-bar-track{width:220px;height:4px;background:rgba(255,255,255,0.1);border-radius:2px;margin-top:4px;border:1px solid rgba(100,150,255,0.2)}
#armor-bar-fill{height:100%;width:100%;background:linear-gradient(90deg,#2244ff,#6688ff);border-radius:2px;transition:width .3s}

/* AMMO */
#ammo-wrap{position:absolute;bottom:28px;right:28px;text-align:right}
#weapon-name{font-family:'Orbitron',monospace;font-size:11px;letter-spacing:3px;color:#ffcc00;text-shadow:0 0 8px rgba(255,200,0,0.6);margin-bottom:4px}
#ammo-nums{font-family:'Orbitron',monospace;font-size:38px;font-weight:900;color:#fff;line-height:1}
#ammo-reserve{font-family:'Exo 2',sans-serif;font-size:13px;color:rgba(255,255,255,0.4);margin-top:2px}
#weapon-icons{display:flex;gap:6px;justify-content:flex-end;margin-top:8px}
.w-icon{width:32px;height:18px;border:1px solid rgba(255,255,255,0.15);border-radius:3px;display:flex;align-items:center;justify-content:center;font-size:9px;color:rgba(255,255,255,0.3);cursor:pointer;transition:all .2s;font-family:'Orbitron',monospace}
.w-icon.active{border-color:#ffcc00;color:#ffcc00;background:rgba(255,200,0,0.1);box-shadow:0 0 8px rgba(255,200,0,0.3)}

/* KILLS / SCORE TOP */
#topbar{position:absolute;top:0;left:50%;transform:translateX(-50%);padding:10px 30px;background:rgba(0,0,0,0.4);border-bottom:1px solid rgba(255,255,255,0.08);display:flex;gap:40px;align-items:center;border-radius:0 0 12px 12px}
.topstat{text-align:center}
.topstat-val{font-family:'Orbitron',monospace;font-size:22px;font-weight:700;color:#fff}
.topstat-label{font-size:9px;letter-spacing:2px;color:rgba(255,255,255,0.4);text-transform:uppercase}
#ping-dot{width:8px;height:8px;border-radius:50%;background:#2ecc71;animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
#ping-val{font-size:11px;color:rgba(255,255,255,0.5);font-family:'Orbitron',monospace}

/* SCOREBOARD */
#scoreboard{position:absolute;top:70px;left:20px;background:rgba(0,0,0,0.55);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:12px 16px;min-width:200px;backdrop-filter:blur(6px)}
#scoreboard h3{font-family:'Orbitron',monospace;font-size:11px;letter-spacing:3px;color:#ffcc00;margin-bottom:10px;text-transform:uppercase}
.s-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0;font-size:12px;border-bottom:1px solid rgba(255,255,255,0.05)}
.s-row:last-child{border:none}
.s-row.you{color:#4af;font-weight:600}
.s-row .s-name{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:120px}
.s-row .s-kd{color:rgba(255,255,255,0.5);font-family:'Orbitron',monospace;font-size:11px}
.s-row .s-badge{width:6px;height:6px;border-radius:50%;background:#2ecc71;margin-right:6px;flex-shrink:0}
.s-row .s-badge.red{background:#ff4444}

/* KILLFEED */
#killfeed{position:absolute;top:70px;right:20px;display:flex;flex-direction:column;gap:5px;align-items:flex-end}
.kf{background:rgba(0,0,0,0.65);border:1px solid rgba(255,255,255,0.08);padding:5px 12px;border-radius:4px;font-size:12px;color:#fff;animation:kfIn .2s ease,kfOut .4s ease 2.6s forwards;border-left:3px solid #ff4444}
.kf .kf-you{color:#4af}
@keyframes kfIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:none}}
@keyframes kfOut{to{opacity:0;transform:translateX(10px)}}

/* DAMAGE VIGNETTE */
#dmg{position:absolute;inset:0;background:radial-gradient(ellipse,transparent 50%,rgba(255,0,0,0) 100%);opacity:0;transition:opacity .15s;pointer-events:none}
#dmg.flash{background:radial-gradient(ellipse,transparent 40%,rgba(220,0,0,0.55) 100%)}

/* HITMARKER */
#hm{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0;transition:opacity .08s;width:28px;height:28px}

/* RELOAD */
#reload{position:absolute;bottom:120px;left:50%;transform:translateX(-50%);color:#ffcc00;font-family:'Orbitron',monospace;font-size:12px;letter-spacing:2px;opacity:0;transition:opacity .2s;text-shadow:0 0 8px #ffcc00}

/* MINIMAP */
#mmap{position:absolute;bottom:28px;right:220px;width:130px;height:130px;border-radius:50%;overflow:hidden;border:2px solid rgba(255,255,255,0.15);box-shadow:0 0 20px rgba(0,0,0,0.5)}
#mmapCanvas{width:100%;height:100%}

/* LOCK SCREEN */
#lock{position:fixed;inset:0;z-index:100;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#040810}
#lock-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 60%,rgba(255,30,30,0.12) 0%,transparent 70%)}
#lock h1{font-family:'Orbitron',monospace;font-size:64px;font-weight:900;color:#fff;letter-spacing:4px;text-shadow:0 0 40px rgba(255,50,50,0.7),0 0 80px rgba(255,50,50,0.3);position:relative;z-index:1;margin-bottom:4px}
#lock .sub{font-family:'Exo 2',sans-serif;font-size:13px;letter-spacing:6px;color:rgba(255,100,100,0.6);text-transform:uppercase;margin-bottom:40px;z-index:1;position:relative}
#lock .controls{z-index:1;position:relative;color:rgba(255,255,255,0.4);font-size:12px;line-height:2;text-align:center;margin-bottom:36px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:8px;padding:16px 28px;letter-spacing:1px}
#lock .controls span{color:rgba(100,180,255,0.8);font-family:'Orbitron',monospace;font-size:10px}
#playbtn{font-family:'Orbitron',monospace;font-size:15px;letter-spacing:4px;font-weight:700;padding:16px 52px;background:linear-gradient(135deg,#ff2244,#cc0022);color:#fff;border:none;border-radius:6px;cursor:pointer;position:relative;z-index:1;text-transform:uppercase;box-shadow:0 4px 30px rgba(255,30,50,0.5);transition:all .2s}
#playbtn:hover{transform:scale(1.04);box-shadow:0 6px 40px rgba(255,30,50,0.7)}

/* DEATH SCREEN */
#dscreen{position:fixed;inset:0;z-index:50;display:none;flex-direction:column;align-items:center;justify-content:center;background:rgba(180,0,0,0.2);backdrop-filter:blur(2px)}
#dscreen h2{font-family:'Orbitron',monospace;font-size:56px;font-weight:900;color:#ff3344;text-shadow:0 0 30px rgba(255,0,0,0.8);letter-spacing:4px}
#dscreen p{color:rgba(255,255,255,0.6);font-size:14px;letter-spacing:2px;margin-top:12px;font-family:'Orbitron',monospace}

/* MUZZLE FLASH */
#mflash{position:absolute;width:60px;height:60px;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0;background:radial-gradient(circle,rgba(255,220,100,0.95),rgba(255,100,0,0.6),transparent);border-radius:50%;pointer-events:none;transition:opacity .05s}
</style>
</head>
<body>
<div id="lock">
  <div id="lock-bg"></div>
  <h1>VEXRIVAL</h1>
  <div class="sub">3D COMBAT — ONLINE MODE</div>
  <div class="controls">
    <span>W A S D</span> Déplacer &nbsp;|&nbsp; <span>SOURIS</span> Viser &nbsp;|&nbsp; <span>CLIC</span> Tirer<br>
    <span>R</span> Recharger &nbsp;|&nbsp; <span>ESPACE</span> Sauter &nbsp;|&nbsp; <span>SHIFT</span> Sprinter<br>
    <span>1 2 3</span> Changer d'arme &nbsp;|&nbsp; <span>G</span> Grenade
  </div>
  <button id="playbtn" onclick="startGame()">▶ LANCER LA PARTIE</button>
</div>

<div id="dscreen">
  <h2>☠ ÉLIMINÉ</h2>
  <p>RÉAPPARITION DANS <span id="rtimer">3</span>s…</p>
</div>

<div id="hud">
  <div id="xhair"><div id="xhair-dot"></div></div>
  <div id="dmg"></div>
  <svg id="hm" viewBox="0 0 28 28"><line x1="0" y1="0" x2="8" y2="8" stroke="#fff" stroke-width="2.5"/><line x1="20" y1="0" x2="28" y2="8" stroke="#fff" stroke-width="2.5"/><line x1="0" y1="28" x2="8" y2="20" stroke="#fff" stroke-width="2.5"/><line x1="20" y1="28" x2="28" y2="20" stroke="#fff" stroke-width="2.5"/></svg>
  <div id="mflash"></div>
  <div id="health-wrap">
    <div id="health-label">❤ VIE</div>
    <div id="health-bar-track"><div id="health-bar-fill"></div></div>
    <div id="health-num">100</div>
    <div id="armor-bar-track"><div id="armor-bar-fill"></div></div>
  </div>
  <div id="ammo-wrap">
    <div id="weapon-name">FUSIL D'ASSAUT</div>
    <div id="ammo-nums">30</div>
    <div id="ammo-reserve">/ 90 en réserve</div>
    <div id="weapon-icons">
      <div class="w-icon active" onclick="swWeapon(0)" id="wi0">AR</div>
      <div class="w-icon" onclick="swWeapon(1)" id="wi1">9M</div>
      <div class="w-icon" onclick="swWeapon(2)" id="wi2">SG</div>
    </div>
  </div>
  <div id="topbar">
    <div class="topstat"><div class="topstat-val" id="stat-kills">0</div><div class="topstat-label">Kills</div></div>
    <div class="topstat"><div class="topstat-val" id="stat-deaths">0</div><div class="topstat-label">Morts</div></div>
    <div class="topstat"><div class="topstat-val" id="stat-kd">0.0</div><div class="topstat-label">K/D</div></div>
    <div style="display:flex;align-items:center;gap:6px"><div id="ping-dot"></div><div id="ping-val">32ms</div></div>
  </div>
  <div id="scoreboard"><h3>🏆 Classement</h3><div id="slist"></div></div>
  <div id="killfeed"></div>
  <div id="mmap"><canvas id="mmapCanvas" width="130" height="130"></canvas></div>
  <div id="reload">⟳ RECHARGEMENT…</div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
// ===========================================================
//  VEXRIVAL 3D — Full FPS Game Engine
// ===========================================================

let scene, camera, renderer, clock, gameRunning = false;

const P = { // Player state
  pos: new THREE.Vector3(5, 1.75, 5),
  vel: new THREE.Vector3(),
  yaw: 0, pitch: 0,
  health: 100, armor: 100,
  kills: 0, deaths: 0,
  onGround: false,
  bobT: 0, bobX: 0, bobY: 0,
  dead: false, reloading: false,
  wIdx: 0,
  name: 'Vous'
};

const WEAPONS = [
  {name:"FUSIL D'ASSAUT", ammo:30, maxAmmo:30, reserve:90, dmg:18, rate:110, spread:0.025, auto:true, color:0x333333, reloadT:2.2},
  {name:"PISTOLET 9MM",   ammo:15, maxAmmo:15, reserve:75, dmg:30, rate:280, spread:0.012, auto:false,color:0x222222, reloadT:1.6},
  {name:"FUSIL À POMPE",  ammo:6,  maxAmmo:6,  reserve:30, dmg:75, rate:800, spread:0.09, auto:false,color:0x553311,pellets:7, reloadT:2.8}
];

const keys = {};
let mDown = false, lastShot = 0, kickOff = 0, kickV = 0;
const collidables = [], bots = [], particles = [];
let weaponGroup, muzzleLight;

// ===========================================================
// TEXTURES — procedural canvas generation
// ===========================================================
function mkTex(fn, size=256, rpt=4){
  const c=document.createElement('canvas'); c.width=c.height=size;
  const x=c.getContext('2d'); fn(x,size);
  const t=new THREE.CanvasTexture(c);
  t.wrapS=t.wrapT=THREE.RepeatWrapping; t.repeat.set(rpt,rpt);
  return t;
}

const TEX = {
  grass: mkTex((x,s)=>{
    x.fillStyle='#2d5a1e'; x.fillRect(0,0,s,s);
    for(let i=0;i<300;i++){
      x.fillStyle=`hsl(${90+~~(Math.random()*30)},${40+~~(Math.random()*30)}%,${18+~~(Math.random()*18)}%)`;
      x.beginPath(); x.ellipse(Math.random()*s,Math.random()*s,2+Math.random()*7,1+Math.random()*4,Math.random()*Math.PI,0,Math.PI*2); x.fill();
    }
  },512,20),
  concrete: mkTex((x,s)=>{
    x.fillStyle='#7a7a82'; x.fillRect(0,0,s,s);
    for(let i=0;i<120;i++){x.strokeStyle=`rgba(0,0,0,${Math.random()*0.12})`;x.lineWidth=1;x.beginPath();x.moveTo(Math.random()*s,Math.random()*s);x.lineTo(Math.random()*s,Math.random()*s);x.stroke();}
    x.strokeStyle='rgba(0,0,0,0.18)';x.lineWidth=1.5;
    for(let i=0;i<s;i+=40){x.beginPath();x.moveTo(i,0);x.lineTo(i,s);x.stroke();x.beginPath();x.moveTo(0,i);x.lineTo(s,i);x.stroke();}
  },256,3),
  brick: mkTex((x,s)=>{
    x.fillStyle='#444'; x.fillRect(0,0,s,s);
    const bw=60,bh=28;
    for(let r=0;r*bh<s+bh;r++){
      const off=(r%2)*bw/2;
      for(let c=0;c*bw<s+bw;c++){
        x.fillStyle=`hsl(${10+~~(Math.random()*12)},${55+~~(Math.random()*20)}%,${35+~~(Math.random()*12)}%)`;
        x.fillRect(c*bw-off+1,r*bh+1,bw-2,bh-2);
      }
    }
  },256,4),
  metal: mkTex((x,s)=>{
    const g=x.createLinearGradient(0,0,s,0); g.addColorStop(0,'#555');g.addColorStop(.5,'#aaa');g.addColorStop(1,'#555');
    x.fillStyle=g; x.fillRect(0,0,s,s);
    for(let i=0;i<8;i++){x.strokeStyle=`rgba(255,255,255,${Math.random()*0.08})`;x.lineWidth=1;x.beginPath();x.moveTo(0,Math.random()*s);x.lineTo(s,Math.random()*s);x.stroke();}
  },128,2),
  asphalt: mkTex((x,s)=>{
    x.fillStyle='#222'; x.fillRect(0,0,s,s);
    for(let i=0;i<200;i++){x.fillStyle=`rgba(255,255,255,${Math.random()*0.04})`;x.fillRect(Math.random()*s,Math.random()*s,2,2);}
  },256,8)
};

// ===========================================================
// SCENE
// ===========================================================
function initScene(){
  scene=new THREE.Scene();
  scene.fog=new THREE.FogExp2(0x253040,0.007);
  scene.background=new THREE.Color(0x253040);
  camera=new THREE.PerspectiveCamera(75,innerWidth/innerHeight,0.05,400);
  renderer=new THREE.WebGLRenderer({antialias:true,powerPreference:'high-performance'});
  renderer.setSize(innerWidth,innerHeight);
  renderer.setPixelRatio(Math.min(devicePixelRatio,2));
  renderer.shadowMap.enabled=true;
  renderer.shadowMap.type=THREE.PCFSoftShadowMap;
  renderer.toneMapping=THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure=1.1;
  renderer.domElement.id='gameCanvas';
  document.body.appendChild(renderer.domElement);
  clock=new THREE.Clock();

  // Lights
  scene.add(new THREE.AmbientLight(0x334455,0.8));
  const sun=new THREE.DirectionalLight(0xffeedd,1.4); sun.position.set(80,120,60);
  sun.castShadow=true; sun.shadow.mapSize.width=sun.shadow.mapSize.height=2048;
  sun.shadow.camera.left=-160; sun.shadow.camera.right=160;
  sun.shadow.camera.top=160; sun.shadow.camera.bottom=-160;
  sun.shadow.camera.far=500; sun.shadow.bias=-0.001;
  scene.add(sun);
  scene.add(new THREE.HemisphereLight(0x4477aa,0x224411,0.5));
  muzzleLight=new THREE.PointLight(0xffaa44,0,8); scene.add(muzzleLight);

  buildMap();
  buildWeapon();
  spawnBots(7);
}

// ===========================================================
// MAP
// ===========================================================
function box(x,y,z,w,h,d,mat,addCol=true){
  const m=new THREE.Mesh(new THREE.BoxGeometry(w,h,d),mat);
  m.position.set(x,y+h/2,z); m.castShadow=true; m.receiveShadow=true;
  scene.add(m);
  if(addCol) collidables.push({min:new THREE.Vector3(x-w/2,y,z-d/2),max:new THREE.Vector3(x+w/2,y+h,z+d/2),m});
  return m;
}
function boxM(x,y,z,w,h,d,c){return box(x,y,z,w,h,d,new THREE.MeshLambertMaterial({color:c,map:TEX.concrete}));}
function plane(y,geo,mat){const m=new THREE.Mesh(geo,mat);m.rotation.x=-Math.PI/2;m.position.y=y;m.receiveShadow=true;scene.add(m);return m;}

function buildMap(){
  // Ground
  plane(0,new THREE.PlaneGeometry(320,320,1,1),new THREE.MeshLambertMaterial({map:TEX.grass}));

  const CMat=new THREE.MeshLambertMaterial({map:TEX.concrete});
  const BMat=new THREE.MeshLambertMaterial({map:TEX.brick});
  const MMat=new THREE.MeshLambertMaterial({map:TEX.metal});
  const AMat=new THREE.MeshLambertMaterial({map:TEX.asphalt});

  // Perimeter walls
  [[0,0,-90,180,8,3],[0,0,90,180,8,3],[90,0,0,3,8,180],[-90,0,0,3,8,180]].forEach(([x,y,z,w,h,d])=>box(x,y,z,w,h,d,CMat));

  // Central fortress
  box(0,0,0,22,12,22,BMat);
  box(0,12,0,18,2,18,MMat); // roof
  // Fortress windows (decorative cutout look)
  [[-8,0,-11,4,6,1],[8,0,-11,4,6,1],[0,0,11,14,6,1],[11,0,0,1,6,14],[-11,0,0,1,6,14]].forEach(([x,y,z,w,h,d])=>box(x,y,z,w,h,d,new THREE.MeshLambertMaterial({color:0x111111})));

  // Roads
  plane(0.01,new THREE.PlaneGeometry(12,180),AMat);
  plane(0.01,new THREE.PlaneGeometry(180,12),AMat);

  // Road lines
  const lMat=new THREE.MeshBasicMaterial({color:0xffdd00});
  for(let i=-80;i<80;i+=10){
    const lm=new THREE.Mesh(new THREE.PlaneGeometry(0.4,5),lMat);
    lm.rotation.x=-Math.PI/2; lm.position.set(0,0.02,i); scene.add(lm);
    const lm2=new THREE.Mesh(new THREE.PlaneGeometry(5,0.4),lMat);
    lm2.rotation.x=-Math.PI/2; lm2.position.set(i,0.02,0); scene.add(lm2);
  }

  // Buildings
  const buildings=[
    [-45,0,-45,20,14,16],[45,0,-45,16,18,20],[45,0,45,22,10,14],[-45,0,45,14,16,22],
    [-65,0,0,8,20,8],[65,0,0,8,20,8],[0,0,-65,8,20,8],[0,0,65,8,20,8],
  ];
  buildings.forEach(([x,y,z,w,h,d])=>{
    box(x,y,z,w,h,d,BMat);
    box(x,h,z,w+1,1.5,d+1,MMat); // roof ledge
  });

  // Crates
  const cMat=new THREE.MeshLambertMaterial({color:0x8B6914,map:TEX.metal});
  [[-12,0,22,3,3,3],[12,0,22,3,3,3],[-12,0,-22,3,3,3],[12,0,-22,3,3,3],
   [22,0,0,3,4,3],[-22,0,0,3,4,3],[0,0,22,4,3,4],[0,0,-22,4,3,4],
   [30,0,30,3,3,3],[-30,0,30,3,3,3],[30,0,-30,3,3,3],[-30,0,-30,3,3,3],
   [-55,0,25,3,3,3],[55,0,-25,3,3,3],[55,0,25,3,3,3],[-55,0,-25,3,3,3]
  ].forEach(([x,y,z,w,h,d])=>box(x,y,z,w,h,d,cMat));

  // Concrete barriers
  [[-25,0,10,1.5,2.5,10],[25,0,-10,1.5,2.5,10],[0,0,-35,14,2.5,1.5],[0,0,35,14,2.5,1.5],
   [-35,0,0,1.5,2.5,14],[35,0,0,1.5,2.5,14],
   [-70,0,-30,2,3,12],[-70,0,30,2,3,12],[70,0,-30,2,3,12],[70,0,30,2,3,12],
