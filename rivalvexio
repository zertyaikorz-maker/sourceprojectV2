// PARTICLES
// ===========================================================
function spawnParts(pos,color){
  for(let i=0;i<7;i++){
    const m=new THREE.Mesh(new THREE.SphereGeometry(0.045,4,4),new THREE.MeshBasicMaterial({color,transparent:true}));
    m.position.copy(pos); scene.add(m);
    particles.push({mesh:m,vel:new THREE.Vector3((Math.random()-.5)*6,Math.random()*5+1,(Math.random()-.5)*6),life:0.55,maxLife:0.55});
  }
}
function updParts(dt){
  for(let i=particles.length-1;i>=0;i--){
    const p=particles[i]; p.life-=dt;
    if(p.life<=0){scene.remove(p.mesh);particles.splice(i,1);continue;}
    if(!p.scale) p.vel.y-=14*dt;
    p.mesh.position.addScaledVector(p.vel,dt);
    if(p.mesh.material.opacity!==undefined) p.mesh.material.opacity=p.life/p.maxLife;
    if(p.scale) p.mesh.scale.setScalar(1+2*(1-p.life/p.maxLife));
  }
}

// ===========================================================
// BOT AI
// ===========================================================
function updBots(dt){
  const now=Date.now();
  bots.forEach(b=>{
    if(b.dead){
      b.respawnT-=dt;
      if(b.respawnT<=0){
        b.g.position.copy(b.spawn); b.g.rotation.x=0;
        b.health=100; b.dead=false; b.state='roam';
      }
      return;
    }
    const bp=b.g.position, pd=bp.distanceTo(P.pos);
    b.state= pd<28&&!P.dead ? 'attack' : pd<55 ? 'chase' : 'roam';
    if(b.state==='roam'){
      b.wanderT-=dt;
      if(b.wanderT<=0){b.wanderTarget.set((Math.random()-.5)*160,1.25,(Math.random()-.5)*160);b.wanderT=2.5+Math.random()*3;}
      moveTo(b,b.wanderTarget,dt);
    } else if(b.state==='chase'){
      moveTo(b,P.pos,dt*0.9);
    } else {
      const ang=Math.atan2(P.pos.x-bp.x,P.pos.z-bp.z);
      b.g.rotation.y=ang;
      const strafe=new THREE.Vector3(Math.sin(ang+Math.PI/2),0,Math.cos(ang+Math.PI/2));
      bp.addScaledVector(strafe,Math.sin(now*0.0015)*2.5*dt);
      if(!P.dead&&now-b.lastShot>b.shotInt){
        b.lastShot=now; botFire(b);
      }
    }
    bp.x=Math.max(-88,Math.min(88,bp.x));
    bp.z=Math.max(-88,Math.min(88,bp.z));
    bp.y=1.25;
  });
}
function moveTo(b,tgt,dt){
  const d=tgt.clone().sub(b.g.position); d.y=0;
  if(d.length()<1.5) return; d.normalize();
  b.g.position.x+=d.x*b.spd*dt;
  b.g.position.z+=d.z*b.spd*dt;
  b.g.rotation.y=Math.atan2(d.x,d.z);
}
function botFire(b){
  if(P.dead) return;
  const acc=0.62+Math.random()*0.25;
  if(Math.random()<acc){hurtPlayer(9+Math.random()*8);}
  const from=b.g.position.clone().add(new THREE.Vector3(0,0.5,0));
  const to=P.pos.clone();
  const gl=new THREE.Mesh(new THREE.CylinderGeometry(0.018,0.018,from.distanceTo(to),4),new THREE.MeshBasicMaterial({color:0xffee55,transparent:true,opacity:0.5}));
  const mid=from.clone().add(to).multiplyScalar(0.5); gl.position.copy(mid);
  gl.lookAt(to); gl.rotateX(Math.PI/2); scene.add(gl);
  particles.push({mesh:gl,vel:new THREE.Vector3(),life:0.08,maxLife:0.08});
}

