// ===========================================================
function swWeapon(i){
  if(i===P.wIdx||P.reloading) return;
  P.wIdx=i; P.reloading=false;
  rebuildGun();
  document.querySelectorAll('.w-icon').forEach((el,j)=>el.classList.toggle('active',j===i));
  document.getElementById('weapon-name').textContent=WEAPONS[i].name;
  updateAmmoHUD();
}

const RC=new THREE.Raycaster();
function doShoot(){
  if(P.dead||P.reloading) return;
  const now=Date.now(), w=WEAPONS[P.wIdx];
  if(now-lastShot<w.rate) return;
  if(w.ammo<=0){startReload();return;}
  lastShot=now; w.ammo--; updateAmmoHUD();
  kickV=0.05; showMFlash();
  const np=w.pellets||1;
  for(let p=0;p<np;p++){
    const sp=w.spread, dir=new THREE.Vector3((Math.random()-.5)*sp,(Math.random()-.5)*sp,-1)
      .applyEuler(new THREE.Euler(P.pitch,P.yaw,0,'YXZ')).normalize();
    rayShoot(dir);
  }
  if(w.ammo===0) setTimeout(startReload,400);
}

function rayShoot(dir){
  const origin=P.pos.clone().add(new THREE.Vector3(0,0.05,0));
  RC.set(origin,dir); RC.far=180;
  const hitObjs=[];
  bots.forEach(b=>{if(!b.dead) b.g.children.forEach(c=>{if(c.isMesh&&c.material.color?.r!==undefined) hitObjs.push(c);})});
  const wallMeshes=collidables.map(c=>c.m).filter(Boolean);
  const botHits=RC.intersectObjects(hitObjs);
  if(botHits.length>0){
    const closest=botHits[0];
    const w=WEAPONS[P.wIdx];
    // Find which bot
    for(const b of bots){
      if(b.dead) continue;
      if(b.g.children.includes(closest.object)||b.g.children.some(c=>c===closest.object)){
        const dmg=w.dmg*(0.85+Math.random()*0.3);
        b.health-=dmg;
        if(b.health<=0&&!b.dead) botKill(b);
        showHM(); spawnParts(closest.point,0xff4444); return;
      }
    }
    showHM(); spawnParts(botHits[0].point,0xff4444); return;
  }
  const wallHits=RC.intersectObjects(wallMeshes);
  if(wallHits.length>0) spawnParts(wallHits[0].point,0xbbbbbb);
}

function botKill(b){
  b.dead=true; b.health=0; P.kills++;
  b.g.rotation.x=Math.PI/2.2; b.g.position.y=0.4;
  b.deaths=(b.deaths||0)+1;
  addKF(P.name,b.name); updateTopbar(); updateSBoard();
  b.respawnT=5+Math.random()*3;
}

function startReload(){
  const w=WEAPONS[P.wIdx];
  if(P.reloading||w.reserve<=0||w.ammo===w.maxAmmo) return;
  P.reloading=true;
  document.getElementById('reload').style.opacity='1';
  setTimeout(()=>{
    const need=w.maxAmmo-w.ammo, take=Math.min(need,w.reserve);
    w.ammo+=take; w.reserve-=take;
    P.reloading=false;
    document.getElementById('reload').style.opacity='0';
    updateAmmoHUD();
  },WEAPONS[P.wIdx].reloadT*1000);
}

function throwGrenade(){
  if(P.dead) return;
  const dir=new THREE.Vector3(-Math.sin(P.yaw)*Math.cos(P.pitch),-Math.sin(P.pitch)+0.3,-Math.cos(P.yaw)*Math.cos(P.pitch)).normalize();
  const gMesh=new THREE.Mesh(new THREE.SphereGeometry(0.12,8,8),new THREE.MeshLambertMaterial({color:0x445522}));
  gMesh.position.copy(P.pos).add(new THREE.Vector3(0,0.2,0));
  scene.add(gMesh);
  let t=0; const vel=dir.clone().multiplyScalar(18); vel.y+=5;
  const tick=setInterval(()=>{
    t+=0.016; vel.y-=0.016*22; gMesh.position.addScaledVector(vel,0.016);
    if(gMesh.position.y<0.15){gMesh.position.y=0.15; vel.y*=-0.3; vel.x*=0.7; vel.z*=0.7;}
    if(t>3){
      clearInterval(tick); grenadeExplode(gMesh.position.clone()); scene.remove(gMesh);
    }
  },16);
}

function grenadeExplode(pos){
  // Shockwave ring
  const geo=new THREE.RingGeometry(0,6,32);
  const mat=new THREE.MeshBasicMaterial({color:0xff8800,side:THREE.DoubleSide,transparent:true,opacity:0.7});
  const ring=new THREE.Mesh(geo,mat); ring.rotation.x=-Math.PI/2; ring.position.copy(pos); ring.position.y=0.1;
  scene.add(ring); particles.push({mesh:ring,vel:new THREE.Vector3(),life:0.5,maxLife:0.5,scale:true,startScale:1});
  // Sparks
  for(let i=0;i<30;i++) spawnParts(pos.clone().add(new THREE.Vector3((Math.random()-.5)*2,Math.random()*2,(Math.random()-.5)*2)),0xff6600);
  // Damage bots in radius
  bots.forEach(b=>{if(!b.dead&&b.g.position.distanceTo(pos)<7){b.health-=60+Math.random()*40;if(b.health<=0)botKill(b);}});
  if(P.pos.distanceTo(pos)<7&&!P.dead) hurtPlayer(40+Math.random()*30);
  // Flash light
  const fl=new THREE.PointLight(0xff6600,8,20); fl.position.copy(pos); fl.position.y+=1; scene.add(fl);
  setTimeout(()=>scene.remove(fl),200);
}

