function hurtPlayer(dmg){
  if(P.dead) return;
  P.health=Math.max(0,P.health-dmg);
  const ov=document.getElementById('dmg');
  ov.className='flash'; ov.style.opacity='1';
  setTimeout(()=>{ov.style.opacity='0'; setTimeout(()=>ov.className='',300);},180);
  document.getElementById('health-num').textContent=~~P.health;
  document.getElementById('health-bar-fill').style.width=P.health+'%';
  const h=P.health;
  document.getElementById('health-bar-fill').style.background=h>50?'linear-gradient(90deg,#ff2244,#ff6677)':h>25?'linear-gradient(90deg,#ff7700,#ffaa00)':'linear-gradient(90deg,#ff0000,#cc0000)';
  if(P.health<=0) diePlayer();
}
function diePlayer(){
  P.dead=true; P.deaths++;
  document.getElementById('dscreen').style.display='flex';
  let t=3; document.getElementById('rtimer').textContent=t;
  const iv=setInterval(()=>{t--;document.getElementById('rtimer').textContent=t;
    if(t<=0){clearInterval(iv);respawnPlayer();}},1000);
  updateTopbar(); updateSBoard();
}
function respawnPlayer(){
  const sp=SPAWNS[~~(Math.random()*SPAWNS.length)];
  P.pos.set(sp[0],1.75,sp[1]); P.vel.set(0,0,0);
  P.health=100; P.armor=100; P.dead=false;
  document.getElementById('dscreen').style.display='none';
  document.getElementById('health-num').textContent='100';
  document.getElementById('health-bar-fill').style.width='100%';
  document.getElementById('armor-bar-fill').style.width='100%';
  document.getElementById('health-bar-fill').style.background='linear-gradient(90deg,#ff2244,#ff6677)';
  WEAPONS.forEach(w=>{w.ammo=w.maxAmmo;}); updateAmmoHUD();
}

const G=-22, JVEL=8.5, WLK=6.5, RUN=11;
function updPlayer(dt){
  if(P.dead) return;
  if(mDown&&WEAPONS[P.wIdx].auto) doShoot();
  const run=keys['ShiftLeft']||keys['ShiftRight'];
  const spd=run?RUN:WLK;
  const fwd=new THREE.Vector3(-Math.sin(P.yaw),0,-Math.cos(P.yaw));
  const rgt=new THREE.Vector3(Math.cos(P.yaw),0,-Math.sin(P.yaw));
  const mv=new THREE.Vector3();
  if(keys['KeyW']||keys['ArrowUp']) mv.addScaledVector(fwd,spd);
  if(keys['KeyS']||keys['ArrowDown']) mv.addScaledVector(fwd,-spd*0.7);
  if(keys['KeyA']||keys['ArrowLeft']) mv.addScaledVector(rgt,-spd*0.8);
  if(keys['KeyD']||keys['ArrowRight']) mv.addScaledVector(rgt,spd*0.8);
  P.vel.x=mv.x; P.vel.z=mv.z;
  if(keys['Space']&&P.onGround){P.vel.y=JVEL; P.onGround=false;}
  P.vel.y+=G*dt;
  const np=P.pos.clone().addScaledVector(P.vel,dt);
  if(np.y<1.75){np.y=1.75;P.vel.y=0;P.onGround=true;}
  // Collision
  const R=0.42;
  for(const col of collidables){
    const ex={min:col.min.clone().subScalar(R),max:col.max.clone().addScalar(R)};
    if(np.x>ex.min.x&&np.x<ex.max.x&&np.y>col.min.y-0.2&&np.y<col.max.y+0.6&&np.z>ex.min.z&&np.z<ex.max.z){
      const ox=Math.min(np.x-ex.min.x,ex.max.x-np.x);
      const oz=Math.min(np.z-ex.min.z,ex.max.z-np.z);
      if(ox<oz) np.x=P.pos.x; else np.z=P.pos.z;
    }
  }
  np.x=Math.max(-88,Math.min(88,np.x)); np.z=Math.max(-88,Math.min(88,np.z));
  P.pos.copy(np);
  const moving=mv.length()>0.1;
  if(moving&&P.onGround) P.bobT+=dt*(run?13:8);
  P.bobX=Math.sin(P.bobT)*0.016; P.bobY=Math.abs(Math.cos(P.bobT))*0.014;
  camera.position.set(P.pos.x+P.bobX,P.pos.y+P.bobY,P.pos.z);
  camera.rotation.order='YXZ'; camera.rotation.y=P.yaw; camera.rotation.x=P.pitch;
  // Weapon
  if(kickV!==0){kickOff+=kickV;kickV*=0.55;if(Math.abs(kickV)<0.001)kickV=0;if(kickOff>0)kickOff-=0.025;if(kickOff<0){kickOff=0;kickV=0;}}
  const wp=new THREE.Vector3(0.24,-0.21,-0.44);
  wp.x+=P.bobX*0.45; wp.y-=P.bobY*0.3+kickOff;
  weaponGroup.position.copy(wp.clone().applyMatrix4(camera.matrixWorld));
  weaponGroup.rotation.copy(camera.rotation);
}

// ===========================================================
// EFFECTS
// ===========================================================
let mfT=0;
function showMFlash(){
  mfT=0.06; muzzleLight.intensity=4;
  document.getElementById('mflash').style.opacity='0.9';
}
function showHM(){
  const h=document.getElementById('hm'); h.style.opacity='1';
  setTimeout(()=>h.style.opacity='0',110);
}

// ===========================================================
// HUD
// ===========================================================
function updateAmmoHUD(){
  const w=WEAPONS[P.wIdx];
  document.getElementById('ammo-nums').textContent=w.ammo;
  document.getElementById('ammo-reserve').textContent=`/ ${w.reserve} en réserve`;
}
function addKF(killer,victim){
  const f=document.getElementById('killfeed');
  const d=document.createElement('div'); d.className='kf';
  d.innerHTML=`<span class="kf-you">${killer}</span> ☠ ${victim}`;
  f.appendChild(d); setTimeout(()=>d.remove(),3200);
}
function updateTopbar(){
  document.getElementById('stat-kills').textContent=P.kills;
  document.getElementById('stat-deaths').textContent=P.deaths;
  const kd=P.deaths>0?(P.kills/P.deaths).toFixed(1):P.kills+'.0';
  document.getElementById('stat-kd').textContent=kd;
}
function updateSBoard(){
  const all=[{name:P.name,kills:P.kills,deaths:P.deaths,you:true},...bots.map(b=>({name:b.name,kills:b.kills,deaths:b.deaths||0}))];
  all.sort((a,b)=>b.kills-a.kills);
  document.getElementById('slist').innerHTML=all.slice(0,7).map(s=>`
    <div class="s-row ${s.you?'you':''}">
      <div class="s-badge ${s.you?'':'red'}"></div>
      <span class="s-name">${s.name}</span>
      <span class="s-kd">${s.kills}/${s.deaths||0}</span>
    </div>`).join('');
}
function updMinimap(){
  const cv=document.getElementById('mmapCanvas'),ctx=cv.getContext('2d');
  const W=cv.width,H=cv.height,sc=W/200;
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='rgba(0,20,0,0.85)'; ctx.fillRect(0,0,W,H);
  // Buildings
  ctx.fillStyle='rgba(100,120,160,0.5)';
  collidables.slice(4).forEach(c=>{
    const cx=(c.min.x+c.max.x)/2, cz=(c.min.z+c.max.z)/2;
    const cw=c.max.x-c.min.x, cd=c.max.z-c.min.z;
    ctx.fillRect(W/2+cx*sc-cw*sc/2,H/2+cz*sc-cd*sc/2,cw*sc,cd*sc);
  });
  // Bots
  bots.forEach(b=>{
    if(b.dead) return;
    ctx.fillStyle='#f44';
    ctx.beginPath(); ctx.arc(W/2+b.g.position.x*sc,H/2+b.g.position.z*sc,2.5,0,Math.PI*2); ctx.fill();
  });
  // Player
  const px=W/2+P.pos.x*sc, pz=H/2+P.pos.z*sc;
  ctx.fillStyle='#4af'; ctx.beginPath(); ctx.arc(px,pz,4,0,Math.PI*2); ctx.fill();
  ctx.strokeStyle='#4af'; ctx.lineWidth=1.5; ctx.beginPath();
  ctx.moveTo(px,pz); ctx.lineTo(px-Math.sin(P.yaw)*10,pz-Math.cos(P.yaw)*10); ctx.stroke();
}
function updPing(){
  const ping=28+~~(Math.random()*18);
  document.getElementById('ping-val').textContent=ping+'ms';
  const dot=document.getElementById('ping-dot');
  dot.style.background=ping<60?'#2ecc71':ping<100?'#f39c12':'#e74c3c';
}

// ===========================================================
// MAIN LOOP
// ===========================================================
let pingT=0;
function loop(){
  if(!gameRunning) return;
  requestAnimationFrame(loop);
  const dt=Math.min(clock.getDelta(),0.05);
  pingT+=dt; if(pingT>3){pingT=0;updPing();}
  updPlayer(dt);
  updBots(dt);
  updParts(dt);
  updMinimap();
  if(mfT>0){mfT-=dt; if(mfT<=0){muzzleLight.intensity=0;document.getElementById('mflash').style.opacity='0';}}
  renderer.render(scene,camera);
}

// ===========================================================
// START
// ===========================================================
function startGame(){
  document.getElementById('lock').style.display='none';
  initScene();
  setupInput();
  updateAmmoHUD(); updateSBoard(); updateTopbar();
  renderer.domElement.requestPointerLock();
  gameRunning=true;
  loop();
  // Simulate online activity
  setInterval(()=>{
    if(!gameRunning) return;
    const rb=bots[~~(Math.random()*bots.length)];
    const rv=bots[~~(Math.random()*bots.length)];
    if(rb&&rv&&rb!==rv&&!rb.dead&&!rv.dead&&Math.random()<0.3){
      rv.health-=30+~~(Math.random()*40);
      if(rv.health<=0){rv.dead=true;rb.kills++;rv.deaths=(rv.deaths||0)+1;rv.respawnT=5;addKF(rb.name,rv.name);updateSBoard();}
    }
  },4000);
}

// Init scoreboard preview
window.addEventListener('DOMContentLoaded',()=>{
  const sl=document.getElementById('slist');
  sl.innerHTML=`<div class="s-row you"><div class="s-badge"></div><span class="s-name">Vous</span><span class="s-kd">0/0</span></div>`
    +BOT_NAMES.slice(0,5).map(n=>`<div class="s-row"><div class="s-badge red"></div><span class="s-name">${n}</span><span class="s-kd">${~~(Math.random()*5)}/${~~(Math.random()*3)}</span></div>`).join('');
});
