<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>∞ COSMOS CRAFT</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --bg:#03030a;
  --panel:rgba(6,6,18,0.97);
  --panel2:rgba(10,10,25,0.95);
  --border:rgba(80,50,160,0.25);
  --text:#ccc4e8;
  --muted:#4a4468;
  --accent:#7c4dff;
  --gold:#f59e0b;
  --sidebar:260px;
  --topbar:54px;
}

html,body{height:100%;overflow:hidden}
body{
  font-family:'Rajdhani',sans-serif;
  background:var(--bg);
  color:var(--text);
  display:flex;
  flex-direction:column;
  cursor:default;
  user-select:none;
}

/* ── STARFIELD ─────────────────────────────── */
#starfield{
  position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden;
}
.star{
  position:absolute;border-radius:50%;background:#fff;
  animation:twinkle var(--d,3s) var(--del,0s) ease-in-out infinite;
}
@keyframes twinkle{0%,100%{opacity:.1;transform:scale(1)}50%{opacity:var(--op,.8);transform:scale(1.5)}}

/* Aurora */
#aurora{
  position:fixed;inset:0;pointer-events:none;z-index:0;
  background:
    radial-gradient(ellipse 70% 40% at 15% 90%,rgba(124,77,255,.06) 0%,transparent 70%),
    radial-gradient(ellipse 50% 30% at 85% 10%,rgba(236,72,153,.05) 0%,transparent 60%);
}

/* ── TOPBAR ─────────────────────────────────── */
#topbar{
  height:var(--topbar);
  display:flex;align-items:center;gap:12px;padding:0 18px;
  background:var(--panel);
  border-bottom:1px solid var(--border);
  position:relative;z-index:100;flex-shrink:0;
  box-shadow:0 2px 40px rgba(0,0,0,.5);
}

.logo{
  font-family:'Orbitron',sans-serif;font-weight:900;font-size:1rem;
  letter-spacing:.18em;white-space:nowrap;flex-shrink:0;
  background:linear-gradient(90deg,#7c4dff,#ec4899,#f59e0b);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 0 12px rgba(124,77,255,.4));
}

/* Mode tabs */
.modes{display:flex;gap:3px;flex:1;justify-content:center;overflow:auto}
.modes::-webkit-scrollbar{display:none}

.m-tab{
  padding:5px 12px;border-radius:6px;border:1px solid transparent;
  background:transparent;color:var(--muted);
  font-family:'Rajdhani',sans-serif;font-size:.82rem;font-weight:600;
  letter-spacing:.08em;cursor:pointer;transition:all .2s;white-space:nowrap;
}
.m-tab:hover{color:var(--text);border-color:var(--border)}
.m-tab.active{background:rgba(124,77,255,.15);border-color:rgba(124,77,255,.5);color:#a78bfa}
.m-tab.danger.active{background:rgba(239,68,68,.15);border-color:rgba(239,68,68,.5);color:#f87171}
.m-tab.cosmos.active{background:rgba(59,130,246,.15);border-color:rgba(59,130,246,.5);color:#93c5fd}
.m-tab.tech.active{background:rgba(34,197,94,.15);border-color:rgba(34,197,94,.5);color:#86efac}
.m-tab.mytho.active{background:rgba(245,158,11,.15);border-color:rgba(245,158,11,.5);color:#fcd34d}

/* Stats */
.tb-stats{display:flex;gap:14px;font-size:.78rem;color:var(--muted);flex-shrink:0}
.tb-stat strong{color:var(--text)}

.tb-btn{
  padding:4px 12px;border:1px solid var(--border);border-radius:6px;
  background:transparent;color:var(--muted);
  font-family:'Rajdhani',sans-serif;font-size:.78rem;cursor:pointer;
  transition:all .2s;flex-shrink:0;
}
.tb-btn:hover{border-color:rgba(239,68,68,.5);color:#f87171}

/* ── APP BODY ────────────────────────────────── */
#app{display:flex;flex:1;overflow:hidden;position:relative;z-index:1}

/* ── SIDEBAR ─────────────────────────────────── */
#sidebar{
  width:var(--sidebar);flex-shrink:0;
  background:var(--panel);
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;overflow:hidden;
}

.sb-head{
  padding:10px 14px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:6px;
  font-size:.65rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);
}
.sb-count{
  margin-left:auto;
  background:rgba(124,77,255,.18);border:1px solid rgba(124,77,255,.35);color:#a78bfa;
  border-radius:20px;padding:1px 9px;font-size:.68rem;
}

.sb-search{padding:8px 10px;border-bottom:1px solid var(--border)}
.sb-search input{
  width:100%;background:rgba(255,255,255,.03);border:1px solid var(--border);
  border-radius:6px;padding:6px 10px;color:var(--text);
  font-family:'Rajdhani',sans-serif;font-size:.88rem;outline:none;
  transition:border-color .2s;
}
.sb-search input:focus{border-color:rgba(124,77,255,.5)}
.sb-search input::placeholder{color:var(--muted)}

#sb-list{
  flex:1;overflow-y:auto;padding:7px;display:flex;flex-direction:column;gap:2px;
}
#sb-list::-webkit-scrollbar{width:3px}
#sb-list::-webkit-scrollbar-thumb{background:rgba(124,77,255,.3);border-radius:2px}

.sb-item{
  display:flex;align-items:center;gap:8px;padding:7px 10px;
  border-radius:7px;border:1px solid transparent;
  background:rgba(255,255,255,.02);cursor:grab;transition:all .15s;
  position:relative;
}
.sb-item:hover{background:rgba(255,255,255,.05);border-color:var(--border);transform:translateX(2px)}
.sb-item:active{cursor:grabbing}

.sb-emoji{font-size:1.2rem;width:24px;text-align:center;flex-shrink:0;line-height:1}
.sb-name{font-size:.88rem;font-weight:500;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sb-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}

/* Rarity colors */
.r0{background:#4b5563}.r1{background:#3b82f6}.r2{background:#a855f7}.r3{background:#f59e0b}.r4{background:#ec4899}.rd{background:#ef4444}

.sb-item.flash{animation:sbflash 2s ease-out forwards}
@keyframes sbflash{
  0%{background:rgba(124,77,255,.35);border-color:rgba(124,77,255,.7)}
  100%{background:rgba(255,255,255,.02);border-color:transparent}
}

/* ── CANVAS ──────────────────────────────────── */
#canvas-wrap{
  flex:1;position:relative;overflow:hidden;
  background-image:
    linear-gradient(rgba(80,50,160,.06) 1px,transparent 1px),
    linear-gradient(90deg,rgba(80,50,160,.06) 1px,transparent 1px);
  background-size:44px 44px;
}

#canvas-hint{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  text-align:center;pointer-events:none;opacity:.35;transition:opacity .6s;
}
#canvas-hint.hide{opacity:0}
.hint-big{font-size:3.5rem;margin-bottom:10px;display:block;animation:floatHint 4s ease-in-out infinite}
@keyframes floatHint{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
#canvas-hint p{font-size:.88rem;color:var(--muted);line-height:1.8;letter-spacing:.05em}

/* ── CANVAS CARDS ────────────────────────────── */
.c-card{
  position:absolute;display:flex;flex-direction:column;align-items:center;
  justify-content:center;gap:4px;padding:10px 14px;min-width:88px;
  border-radius:10px;border:1px solid var(--rc,#4b5563);
  background:rgba(6,6,18,.92);
  box-shadow:0 4px 24px rgba(0,0,0,.6),0 0 12px color-mix(in srgb,var(--rc,#4b5563) 25%,transparent);
  cursor:grab;transition:box-shadow .2s,border-color .2s;
  backdrop-filter:blur(12px);z-index:10;
}
.c-card:hover{
  box-shadow:0 6px 32px rgba(0,0,0,.7),0 0 22px color-mix(in srgb,var(--rc,#4b5563) 50%,transparent);
  z-index:20;
}
.c-card.dragging{
  cursor:grabbing;z-index:200;transition:none;
  box-shadow:0 16px 60px rgba(0,0,0,.9),0 0 40px color-mix(in srgb,var(--rc,#4b5563) 70%,transparent);
  transform:scale(1.06);
}
.c-card.will-combine{
  border-color:#fff !important;
  box-shadow:0 0 0 2px rgba(255,255,255,.5),0 0 40px rgba(255,255,255,.3) !important;
  animation:pulse-card .4s ease-in-out infinite alternate;
}
@keyframes pulse-card{from{transform:scale(1)}to{transform:scale(1.08)}}

.c-card.combining{animation:combine-out .25s ease-in forwards}
@keyframes combine-out{to{transform:scale(0) rotate(180deg);opacity:0}}

.c-emoji{font-size:1.7rem;line-height:1;pointer-events:none}
.c-name{font-size:.72rem;font-weight:600;letter-spacing:.04em;white-space:nowrap;color:var(--text);max-width:100px;text-align:center;pointer-events:none}
.c-del{
  position:absolute;top:2px;right:5px;font-size:.58rem;color:var(--muted);
  cursor:pointer;opacity:0;transition:opacity .15s;line-height:1;
}
.c-card:hover .c-del{opacity:1}

/* Rarity card colors */
.c-r0{--rc:#4b5563}.c-r1{--rc:#3b82f6}.c-r2{--rc:#a855f7}.c-r3{--rc:#f59e0b}
.c-r4{--rc:#ec4899;animation:rainbow-border 3s linear infinite}
.c-rd{--rc:#ef4444;box-shadow:0 0 20px rgba(239,68,68,.3) !important}
@keyframes rainbow-border{
  0%{border-color:#ec4899}25%{border-color:#f59e0b}
  50%{border-color:#7c4dff}75%{border-color:#3b82f6}100%{border-color:#ec4899}
}

/* ── PARTICLES ───────────────────────────────── */
.spark{
  position:fixed;pointer-events:none;border-radius:50%;z-index:500;
  animation:spark-fly var(--sd,.8s) ease-out forwards;
}
@keyframes spark-fly{
  0%{opacity:1;transform:translate(0,0) scale(1)}
  100%{opacity:0;transform:var(--se,translate(40px,-40px)) scale(0)}
}
.floaty{
  position:fixed;pointer-events:none;z-index:501;font-size:1.6rem;
  animation:floaty-up 1s ease-out forwards;
}
@keyframes floaty-up{
  0%{opacity:1;transform:translate(0,0) scale(1)}
  100%{opacity:0;transform:translateY(-90px) scale(.4)}
}

/* ── TOAST ───────────────────────────────────── */
#toast{
  position:fixed;top:64px;right:18px;
  background:rgba(6,6,18,.98);
  border:1px solid var(--border);
  border-radius:12px;padding:13px 18px;
  display:flex;align-items:center;gap:12px;
  min-width:270px;max-width:340px;
  z-index:900;
  transform:translateX(120%);
  transition:transform .4s cubic-bezier(.34,1.56,.64,1);
  backdrop-filter:blur(20px);
  box-shadow:0 20px 60px rgba(0,0,0,.7);
}
#toast.show{transform:translateX(0)}
#toast.t-new{border-color:rgba(124,77,255,.6);box-shadow:0 20px 60px rgba(0,0,0,.7),0 0 30px rgba(124,77,255,.2)}
#toast.t-danger{border-color:rgba(239,68,68,.7);box-shadow:0 20px 60px rgba(0,0,0,.7),0 0 30px rgba(239,68,68,.3)}
#toast.t-legend{border-color:rgba(245,158,11,.7);box-shadow:0 20px 60px rgba(0,0,0,.7),0 0 40px rgba(245,158,11,.35)}

.t-emoji{font-size:2.4rem;flex-shrink:0}
.t-body{flex:1;min-width:0}
.t-label{font-size:.62rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:2px}
.t-label.lnew{color:#a78bfa}.t-label.ldanger{color:#f87171}.t-label.llegend{color:#fcd34d}
.t-name{font-family:'Orbitron',sans-serif;font-size:.95rem;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.t-desc{font-size:.78rem;color:var(--muted);font-style:italic;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* ── EPIC MODAL ──────────────────────────────── */
#modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,.85);
  z-index:950;display:flex;align-items:center;justify-content:center;
  opacity:0;pointer-events:none;transition:opacity .3s;
  backdrop-filter:blur(6px);
}
#modal-overlay.show{opacity:1;pointer-events:auto}

#modal{
  background:radial-gradient(ellipse at top,#180830 0%,#06060f 70%);
  border:1px solid rgba(124,77,255,.55);
  border-radius:20px;padding:48px 56px;text-align:center;
  max-width:380px;width:90%;
  transform:scale(.8);transition:transform .4s cubic-bezier(.34,1.56,.64,1);
  box-shadow:0 0 100px rgba(124,77,255,.25),0 40px 100px rgba(0,0,0,.8);
}
#modal-overlay.show #modal{transform:scale(1)}

#m-emoji{font-size:5rem;display:block;margin-bottom:14px;animation:mfloat 2.5s ease-in-out infinite}
@keyframes mfloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}

#m-badge{
  display:inline-block;font-size:.62rem;font-weight:700;letter-spacing:.25em;
  text-transform:uppercase;padding:3px 14px;border-radius:20px;
  background:rgba(124,77,255,.2);border:1px solid rgba(124,77,255,.5);
  color:#c4b5fd;margin-bottom:14px;
}
#m-name{
  font-family:'Orbitron',sans-serif;font-size:1.7rem;font-weight:900;
  background:linear-gradient(135deg,#f59e0b,#ec4899,#7c4dff);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  margin-bottom:10px;
}
#m-desc{color:var(--muted);font-style:italic;line-height:1.6;font-size:.92rem;margin-bottom:22px}
#m-close{
  font-family:'Rajdhani',sans-serif;font-size:.82rem;font-weight:700;
  letter-spacing:.15em;text-transform:uppercase;
  padding:9px 28px;background:rgba(124,77,255,.2);
  border:1px solid rgba(124,77,255,.5);color:#c4b5fd;
  border-radius:8px;cursor:pointer;transition:all .2s;
}
#m-close:hover{background:rgba(124,77,255,.35);box-shadow:0 0 20px rgba(124,77,255,.3)}

/* ── SCREEN SHAKE ────────────────────────────── */
@keyframes shake{
  0%,100%{transform:translate(0,0)}
  10%{transform:translate(-4px,2px)}
  20%{transform:translate(4px,-2px)}
  30%{transform:translate(-3px,4px)}
  40%{transform:translate(3px,-3px)}
  50%{transform:translate(-4px,1px)}
  60%{transform:translate(4px,1px)}
  70%{transform:translate(-2px,-2px)}
  80%{transform:translate(2px,2px)}
  90%{transform:translate(-2px,-1px)}
}
.shaking{animation:shake .35s ease-out}

/* ── RESULT FLASH ────────────────────────────── */
.result-flash{
  position:fixed;inset:0;pointer-events:none;z-index:490;
  background:radial-gradient(ellipse 50% 50% at 50% 50%,rgba(255,255,255,.12) 0%,transparent 70%);
  animation:flash-out .4s ease-out forwards;
}
@keyframes flash-out{0%{opacity:1}100%{opacity:0}}

/* ── MODE INDICATOR ──────────────────────────── */
#mode-bar{
  position:absolute;bottom:14px;right:16px;
  display:flex;align-items:center;gap:7px;
  font-size:.72rem;font-weight:600;letter-spacing:.1em;
  color:var(--muted);pointer-events:none;
  background:rgba(6,6,18,.8);border:1px solid var(--border);
  border-radius:8px;padding:5px 12px;
  backdrop-filter:blur(8px);
}
#mode-bar .mode-dot{width:7px;height:7px;border-radius:50%}
</style>
</head>
<body>

<div id="starfield"></div>
<div id="aurora"></div>

<!-- TOPBAR -->
<div id="topbar">
  <div class="logo">∞ COSMOS CRAFT</div>

  <div class="modes">
    <button class="m-tab active" onclick="setMode('normal')" data-mode="normal">⚗️ Alchimie</button>
    <button class="m-tab danger" onclick="setMode('danger')" data-mode="danger">☠️ Danger</button>
    <button class="m-tab cosmos" onclick="setMode('cosmos')" data-mode="cosmos">🌌 Cosmos</button>
    <button class="m-tab tech" onclick="setMode('tech')" data-mode="tech">⚡ Tech</button>
    <button class="m-tab mytho" onclick="setMode('mytho')" data-mode="mytho">🐉 Mythes</button>
  </div>

  <div class="tb-stats">
    <div class="tb-stat">Découverts: <strong id="stat-count">4</strong></div>
  </div>
  <button class="tb-btn" onclick="clearCanvas()">🗑 Nettoyer</button>
  <button class="tb-btn" onclick="resetGame()" style="border-color:rgba(239,68,68,.3)">↺ Reset</button>
</div>

<!-- APP BODY -->
<div id="app">

  <!-- SIDEBAR -->
  <div id="sidebar">
    <div class="sb-head">
      📖 Grimoire
      <span class="sb-count" id="sb-count">4</span>
    </div>
    <div class="sb-search">
      <input type="text" placeholder="Rechercher..." id="sb-search" oninput="filterSidebar(this.value)">
    </div>
    <div id="sb-list"></div>
  </div>

  <!-- CANVAS -->
  <div id="canvas-wrap">
    <div id="canvas-hint">
      <span class="hint-big">⚗</span>
      <p>Glisse des éléments ici depuis le grimoire<br>
      Pose un élément <strong>sur un autre</strong> pour les combiner</p>
    </div>

    <div id="mode-bar">
      <div class="mode-dot" id="mode-dot" style="background:#7c4dff"></div>
      <span id="mode-label">Mode Alchimie</span>
    </div>
  </div>
</div>

<!-- TOAST -->
<div id="toast">
  <div class="t-emoji" id="t-emoji">✨</div>
  <div class="t-body">
    <div class="t-label" id="t-label">Nouvelle découverte</div>
    <div class="t-name" id="t-name">Vapeur</div>
    <div class="t-desc" id="t-desc"></div>
  </div>
</div>

<!-- MODAL -->
<div id="modal-overlay">
  <div id="modal">
    <span id="m-emoji">🌟</span>
    <div id="m-badge">✦ DÉCOUVERTE LÉGENDAIRE</div>
    <div id="m-name">Résultat</div>
    <div id="m-desc">Une combinaison extraordinaire.</div>
    <button id="m-close" onclick="closeModal()">Continuer ↩</button>
  </div>
</div>

<script>
/* ════════════════════════════════════════════════════
   COSMOS CRAFT — Built-in Engine v2.0
   ════════════════════════════════════════════════════ */

// ── UTILITIES ────────────────────────────────────────
function norm(s){ return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').trim() }
function ck(a,b){ return [norm(a),norm(b)].sort().join('|') }

// ── COMBINATION DATABASE ─────────────────────────────
const COMBOS = {};
function C(a,b,n,e,r=0,d='',danger=false){
  COMBOS[ck(a,b)]={name:n,emoji:e,rarity:r,desc:d,danger};
}

// 0=commun 1=rare 2=epique 3=legendaire 4=mythique  danger=☠

// BASE
C('Feu','Eau','Vapeur','♨️',0,"L'eau rencontre le feu");
C('Feu','Terre','Lave','🌋',0,"La roche en fusion");
C('Feu','Vent','Soleil','☀️',1,"Lumière et chaleur éternelles");
C('Eau','Terre','Boue','🟤',0,"La terre humide");
C('Eau','Vent','Pluie','🌧️',0,"Le ciel pleure");
C('Terre','Vent','Poussière','🌫️',0,"La terre s'envole");

// VAPEUR
C('Vapeur','Eau','Nuage','☁️',0,"L'eau monte dans les airs");
C('Vapeur','Vent','Brouillard','🌁',0,"La visibilité disparaît");
C('Vapeur','Feu','Explosion','💥',2,"La pression explose",true);
C('Vapeur','Froid','Givre','🌨️',1,"Des cristaux sur les surfaces");

// LAVE
C('Lave','Eau','Roche','🪨',0,"Le magma se solidifie");
C('Lave','Vent','Cendres','🌫️',0,"Les débris volcaniques");
C('Lave','Lave','Volcan','🌋',2,"La montagne en feu");
C('Lave','Mer','Île volcanique','🏝️',2,"Née des profondeurs");

// BOUE
C('Boue','Feu','Brique','🧱',0,"La terre cuite");
C('Boue','Vent','Sable','🏖️',0,"La poussière de la terre");
C('Boue','Soleil','Plante','🌱',0,"La vie qui germe");

// ROCHE
C('Roche','Roche','Montagne','⛰️',1,"Immovable et éternelle");
C('Roche','Eau','Sable','🏖️',0,"L'érosion du temps");
C('Roche','Feu','Métal','⚙️',1,"La roche forgée");
C('Roche','Vent','Poussière','🌫️',0,"La roche s'effrite");
C('Roche','Plante','Mousse','🌿',0,"La vie sur la pierre");
C('Roche','Foudre','Cristal','💎',2,"La foudre dans la roche");

// SABLE
C('Sable','Feu','Verre','🪟',2,"Le sable fondu");
C('Sable','Vent','Désert','🏜️',1,"Un océan de sable");
C('Sable','Eau','Limon','🟡',0,"Le lit de rivière");

// NUAGE
C('Nuage','Nuage','Tempête','⛈️',1,"Les nuages s'accumulent");
C('Nuage','Froid','Neige','❄️',1,"Des cristaux de glace");
C('Nuage','Foudre','Orage','⛈️',1,"Le ciel en colère");

// PLUIE
C('Pluie','Soleil','Arc-en-ciel','🌈',2,"Les couleurs du ciel");
