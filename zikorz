// ── FALLBACK GENERATOR ──────────────────────────────
function smartFallback(a, b) {
  // Category detection
  const fireWords = /feu|flamme|chaud|brûl|lave|soleil|lumière/i;
  const waterWords = /eau|mer|pluie|lac|rivière|neige|glace/i;
  const darkWords = /nuit|mort|obscur|ténèbre|sombre|vampire/i;
  const techWords = /circuit|robot|machine|électr|numérique/i;
  const lifeWords = /vie|plante|animal|humain|dragon|oiseau/i;

  let emoji = b.emoji;
  let rarity = Math.floor(Math.random() * 3);
  let name = a.name + ' ' + b.name;
  let desc = `Une fusion mystérieuse de ${a.name} et ${b.name}`;

  // Try to create meaningful combinations based on patterns
  if (fireWords.test(a.name) && fireWords.test(b.name)) {
    name = 'Inferno Absolu'; emoji = '🔥🌋'; rarity = 3;
    desc = 'Le feu amplifié';
  } else if (waterWords.test(a.name) && darkWords.test(b.name)) {
    name = 'Abîme noir'; emoji = '🌊🖤'; rarity = 2;
    desc = 'Les profondeurs obscures';
  } else if (techWords.test(a.name) && lifeWords.test(b.name)) {
    name = 'Cyborg'; emoji = '🤖💚'; rarity = 3;
    desc = 'La frontière entre vie et machine';
  } else if (darkWords.test(a.name) || darkWords.test(b.name)) {
    rarity = 2;
    name = a.name + ' maudit';
    emoji = '🖤';
    desc = `Touché par l'obscurité`;
  } else {
    // Combine names creatively
    const parts1 = a.name.split(' ');
    const parts2 = b.name.split(' ');
    name = parts1[0] + ' de ' + (parts2[parts2.length-1] || b.name);
    emoji = b.emoji;
  }

  return { name, emoji, rarity, desc, danger: false };
}

// ── GAME STATE ────────────────────────────────────────
let state = {
  mode: 'normal',
  discovered: [],
  canvasItems: [],
  nextId: 0,
  dragging: null,
  dragOffX: 0,
  dragOffY: 0,
};

// ── INIT / SAVE / LOAD ────────────────────────────────
function initGame(mode='normal') {
  const savedAll = getSaved();
  const savedDisc = savedAll[mode] || null;

  const modeData = MODES[mode];
  if (!savedDisc) {
    state.discovered = modeData.starts.map(e=>({...e,id:uid()}));
  } else {
    state.discovered = savedDisc;
  }
  state.canvasItems = [];
  state.mode = mode;

  renderSidebar();
  updateModeBar();
}

function getSaved() {
  try { return JSON.parse(localStorage.getItem('cc_v2')||'{}'); } catch { return {}; }
}

function saveState() {
  const all = getSaved();
  all[state.mode] = state.discovered;
  localStorage.setItem('cc_v2', JSON.stringify(all));
}

function uid() { return ++state.nextId; }

function isKnown(name) {
  return state.discovered.some(e=>norm(e.name)===norm(name));
}

// ── MODE MANAGEMENT ────────────────────────────────────
function setMode(mode) {
  // Clear canvas
  clearCanvas();
  initGame(mode);

  document.querySelectorAll('.m-tab').forEach(t=>{
    t.classList.toggle('active', t.dataset.mode===mode);
  });
}

function updateModeBar() {
  const m = MODES[state.mode];
  document.getElementById('mode-label').textContent = m.label;
  document.getElementById('mode-dot').style.background = m.color;
}

// ── SIDEBAR ────────────────────────────────────────────
let sbFilter = '';

function renderSidebar(filter='') {
  const list = document.getElementById('sb-list');
  const items = filter
    ? [...state.discovered].reverse().filter(e=>e.name.toLowerCase().includes(filter.toLowerCase()))
    : [...state.discovered].reverse();

  list.innerHTML = '';
  items.forEach(el=>{
    const div = document.createElement('div');
    div.className = 'sb-item';
    const cls = el.danger?'rd':`r${el.rarity}`;

    div.innerHTML = `
      <span class="sb-emoji">${el.emoji}</span>
      <span class="sb-name">${el.name}</span>
      <span class="sb-dot ${cls}"></span>
    `;
    div.addEventListener('pointerdown', e=>onSidebarDragStart(e, el));
    div.title = el.desc || el.name;
    list.appendChild(div);
  });

  document.getElementById('sb-count').textContent = state.discovered.length;
  document.getElementById('stat-count').textContent = state.discovered.length;

  const hint = document.getElementById('canvas-hint');
  hint.classList.toggle('hide', state.canvasItems.length > 0);
}

function filterSidebar(v) {
  sbFilter = v;
  renderSidebar(v);
}

// ── SIDEBAR DRAG TO CANVAS ─────────────────────────────
let sidebarDragEl = null;
let sidebarDragData = null;
let sidebarDragActive = false;

function onSidebarDragStart(e, elData) {
  e.preventDefault();
  sidebarDragData = elData;
  sidebarDragActive = true;

  // Create ghost card following mouse
  const ghost = document.createElement('div');
  ghost.id = 'drag-ghost';
  ghost.className = 'c-card ' + (elData.danger?'c-rd':`c-r${elData.rarity}`);
  ghost.style.cssText = `pointer-events:none;z-index:2000;opacity:.85;transition:none;`;
  ghost.innerHTML = `<span class="c-emoji">${elData.emoji}</span><span class="c-name">${elData.name}</span>`;
  ghost.style.left = (e.clientX - 44)+'px';
  ghost.style.top = (e.clientY - 40)+'px';
  document.body.appendChild(ghost);
  sidebarDragEl = ghost;

  document.addEventListener('pointermove', onSidebarDragMove);
  document.addEventListener('pointerup', onSidebarDragEnd);
}

function onSidebarDragMove(e) {
  if (!sidebarDragActive) return;
  sidebarDragEl.style.left = (e.clientX-44)+'px';
  sidebarDragEl.style.top = (e.clientY-40)+'px';
}

function onSidebarDragEnd(e) {
  if (!sidebarDragActive) return;
  sidebarDragActive = false;
  document.removeEventListener('pointermove', onSidebarDragMove);
  document.removeEventListener('pointerup', onSidebarDragEnd);

  // Check if dropped on canvas
  const canvas = document.getElementById('canvas-wrap');
  const cr = canvas.getBoundingClientRect();
  if (e.clientX>cr.left && e.clientX<cr.right && e.clientY>cr.top && e.clientY<cr.bottom) {
    const x = e.clientX - cr.left - 44;
    const y = e.clientY - cr.top - 40;
    addToCanvas(sidebarDragData, x, y);
  }

  sidebarDragEl.remove();
  sidebarDragEl = null;
  sidebarDragData = null;
}

// ── CANVAS MANAGEMENT ─────────────────────────────────
function addToCanvas(elData, x, y) {
  const canvas = document.getElementById('canvas-wrap');
  const id = uid();

  const card = document.createElement('div');
  const rareCls = elData.danger?'c-rd':`c-r${elData.rarity}`;
  card.className = `c-card ${rareCls}`;
  card.dataset.id = id;

  // Clamp to canvas
  const cw = canvas.clientWidth, ch = canvas.clientHeight;
  x = Math.max(0, Math.min(x, cw-100));
  y = Math.max(0, Math.min(y, ch-80));

  card.style.left = x+'px';
  card.style.top = y+'px';
  card.innerHTML = `
    <span class="c-emoji">${elData.emoji}</span>
    <span class="c-name">${elData.name}</span>
    <span class="c-del" title="Supprimer">✕</span>
  `;

  const item = { id, el: card, data: elData };
  state.canvasItems.push(item);
  canvas.appendChild(card);

  card.querySelector('.c-del').addEventListener('click', (e)=>{
    e.stopPropagation();
    removeFromCanvas(id);
  });

  setupCardDrag(item);
  updateHint();

  // Appear animation
  card.style.transform = 'scale(0)';
  card.style.transition = 'transform .25s cubic-bezier(.34,1.56,.64,1)';
  requestAnimationFrame(()=>{ card.style.transform = '' });
  setTimeout(()=>{ card.style.transition = '' }, 300);
}

function removeFromCanvas(id) {
  const idx = state.canvasItems.findIndex(i=>i.id===id);
  if (idx===-1) return;
  const item = state.canvasItems[idx];
  item.el.remove();
  state.canvasItems.splice(idx,1);
  updateHint();
}

function clearCanvas() {
  state.canvasItems.forEach(i=>i.el.remove());
  state.canvasItems = [];
  updateHint();
}

function updateHint() {
  const hint = document.getElementById('canvas-hint');
  hint.classList.toggle('hide', state.canvasItems.length > 0);
}

// ── CARD DRAG (WITHIN CANVAS) ──────────────────────────
function setupCardDrag(item) {
  item.el.addEventListener('pointerdown', e=>startCardDrag(e, item));
}

let activeDrag = null;

function startCardDrag(e, item) {
  if (e.target.classList.contains('c-del')) return;
  e.preventDefault();
  e.stopPropagation();

  const canvas = document.getElementById('canvas-wrap');
  const cr = canvas.getBoundingClientRect();
  const cardRect = item.el.getBoundingClientRect();

  activeDrag = {
    item,
    offX: e.clientX - cardRect.left,
    offY: e.clientY - cardRect.top,
    canvasRect: cr,
  };

  item.el.classList.add('dragging');
  item.el.style.zIndex = 200;

  document.addEventListener('pointermove', onCardDragMove);
  document.addEventListener('pointerup', onCardDragEnd);
}

function onCardDragMove(e) {
  if (!activeDrag) return;
  const { item, offX, offY, canvasRect } = activeDrag;
  const canvas = document.getElementById('canvas-wrap');
  const cw = canvas.clientWidth, ch = canvas.clientHeight;
  const cardW = item.el.offsetWidth, cardH = item.el.offsetHeight;

  let nx = e.clientX - canvasRect.left - offX;
  let ny = e.clientY - canvasRect.top - offY;
  nx = Math.max(0, Math.min(nx, cw-cardW));
  ny = Math.max(0, Math.min(ny, ch-cardH));

  item.el.style.left = nx+'px';
  item.el.style.top = ny+'px';

  // Visual feedback: check overlap with other cards
  const dragRect = item.el.getBoundingClientRect();
  const dragCX = dragRect.left + dragRect.width/2;
  const dragCY = dragRect.top + dragRect.height/2;

  state.canvasItems.forEach(other=>{
    if (other.id===item.id) return;
    const or = other.el.getBoundingClientRect();
    const overlaps = dragCX > or.left && dragCX < or.right && dragCY > or.top && dragCY < or.bottom;
    other.el.classList.toggle('will-combine', overlaps);
  });
}

function onCardDragEnd(e) {
  if (!activeDrag) return;
  document.removeEventListener('pointermove', onCardDragMove);
  document.removeEventListener('pointerup', onCardDragEnd);

  const { item } = activeDrag;
  item.el.classList.remove('dragging');
  item.el.style.zIndex = '';
  activeDrag = null;

  // Check for overlap → combine
  const dragRect = item.el.getBoundingClientRect();
  const dragCX = dragRect.left + dragRect.width/2;
  const dragCY = dragRect.top + dragRect.height/2;

  let target = null;
  for (const other of state.canvasItems) {
    if (other.id===item.id) continue;
    other.el.classList.remove('will-combine');
    const or = other.el.getBoundingClientRect();
    if (dragCX > or.left && dragCX < or.right && dragCY > or.top && dragCY < or.bottom) {
      target = other; break;
    }
  }

  if (target) {
    triggerCombine(item, target);
  }
}

// ── COMBINATION LOGIC ──────────────────────────────────
function triggerCombine(itemA, itemB) {
  const key = ck(itemA.data.name, itemB.data.name);
  let result = COMBOS[key];

  if (!result) {
    result = smartFallback(itemA.data, itemB.data);
  }

  // Get center of target for result card position
  const targetRect = itemB.el.getBoundingClientRect();
  const canvas = document.getElementById('canvas-wrap');
  const cr = canvas.getBoundingClientRect();
  const cx = targetRect.left - cr.left;
  const cy = targetRect.top - cr.top;

  // Animate both cards out
  itemA.el.classList.add('combining');
  itemB.el.classList.add('combining');

  // Spawn particles
  const midX = (itemA.el.getBoundingClientRect().left + targetRect.left) / 2 + 44;
  const midY = (itemA.el.getBoundingClientRect().top + targetRect.top) / 2 + 40;
  spawnParticles(midX, midY, result.danger);

  // Flash
  const flash = document.createElement('div');
  flash.className = 'result-flash';
  document.body.appendChild(flash);
  setTimeout(()=>flash.remove(), 500);

  const isNew = !isKnown(result.name);
  if (isNew) {
    state.discovered.push({...result, id:uid()});
    saveState();
    renderSidebar(sbFilter);
    // Flash new item in sidebar
    setTimeout(()=>{
      const sbItems = document.querySelectorAll('.sb-item');
      if (sbItems[0]) sbItems[0].classList.add('flash');
    }, 100);
  }

  // Remove old cards after animation
  setTimeout(()=>{
    removeFromCanvas(itemA.id);
    removeFromCanvas(itemB.id);
    // Add result card
    addToCanvas(result, cx, cy);

    // Show result notification
    if (isNew || result.rarity >= 3) {
      if (result.rarity >= 4) showModal(result);
      else showToast(result, isNew);
    } else {
      showToast(result, false);
    }

    // Screen shake for dangerous
    if (result.danger) {
      document.getElementById('app').classList.add('shaking');
      setTimeout(()=>document.getElementById('app').classList.remove('shaking'), 400);
    }
  }, 260);
}

// ── PARTICLES ──────────────────────────────────────────
function spawnParticles(cx, cy, danger=false) {
  const colors = danger
    ? ['#ef4444','#f97316','#dc2626','#fca5a5']
    : ['#7c4dff','#ec4899','#f59e0b','#3b82f6','#ffffff'];

  for (let i=0; i<20; i++) {
    const s = document.createElement('div');
    s.className = 'spark';
    const ang = (i/20)*Math.PI*2;
    const dist = 40 + Math.random()*60;
    const ex = Math.cos(ang)*dist, ey = Math.sin(ang)*dist;
    const size = 3+Math.random()*5;
    const color = colors[Math.floor(Math.random()*colors.length)];
    const duration = .4+Math.random()*.5;
    s.style.cssText = `
      left:${cx}px;top:${cy}px;
      width:${size}px;height:${size}px;
      background:${color};
      --se:translate(${ex}px,${ey}px);
      --sd:${duration}s;
      box-shadow:0 0 6px ${color};
    `;
    document.body.appendChild(s);
    setTimeout(()=>s.remove(), duration*1000);
  }

  // Floaty emoji
  for (let i=0; i<4; i++) {
    const f = document.createElement('div');
    f.className = 'floaty';
    f.textContent = danger ? '💥' : ['✨','⭐','🔥','💫'][i%4];
    f.style.left = (cx-20+Math.random()*40)+'px';
    f.style.top = (cy-20)+'px';
    f.style.animationDelay = (i*.1)+'s';
    document.body.appendChild(f);
    setTimeout(()=>f.remove(), 1200);
  }
}

// ── TOAST ──────────────────────────────────────────────
let toastTimer = null;

function showToast(result, isNew) {
  const t = document.getElementById('toast');
  document.getElementById('t-emoji').textContent = result.emoji;
  document.getElementById('t-name').textContent = result.name;
  document.getElementById('t-desc').textContent = result.desc || '';

  const label = document.getElementById('t-label');
  t.className = '';

  if (result.danger && isNew) {
    label.textContent = '☠️ Découverte Dangereuse!';
    label.className = 't-label ldanger';
    t.classList.add('t-danger');
  } else if (result.rarity>=3 && isNew) {
    label.textContent = '✦ Découverte Légendaire!';
    label.className = 't-label llegend';
    t.classList.add('t-legend');
  } else if (isNew) {
    label.textContent = '✦ Nouvelle Découverte';
    label.className = 't-label lnew';
    t.classList.add('t-new');
  } else {
    label.textContent = 'Combinaison';
    label.className = 't-label';
  }

  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>t.classList.remove('show'), 3000);
}

// ── MODAL (MYTHIC) ─────────────────────────────────────
function showModal(result) {
  document.getElementById('m-emoji').textContent = result.emoji;
  document.getElementById('m-name').textContent = result.name;
  document.getElementById('m-desc').textContent = result.desc || 'Une découverte extraordinaire.';

  const badge = document.getElementById('m-badge');
  if (result.danger) {
    badge.textContent = '☠️ CATASTROPHE MYTHIQUE';
    badge.style.cssText = 'background:rgba(239,68,68,.2);border-color:rgba(239,68,68,.5);color:#fca5a5';
  } else {
    badge.textContent = '✦ DÉCOUVERTE MYTHIQUE';
    badge.style.cssText = '';
  }

  document.getElementById('modal-overlay').classList.add('show');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('show');
}

// ── RESET ──────────────────────────────────────────────
function resetGame() {
  if (!confirm('Effacer toutes les découvertes de ce mode?')) return;
  const all = getSaved();
  delete all[state.mode];
  localStorage.setItem('cc_v2', JSON.stringify(all));
  clearCanvas();
  const modeData = MODES[state.mode];
  state.discovered = modeData.starts.map(e=>({...e,id:uid()}));
  renderSidebar();
}

// ── STARFIELD ──────────────────────────────────────────
function buildStarfield() {
  const sf = document.getElementById('starfield');
  const count = 120;
  for (let i=0; i<count; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const size = Math.random()<.8 ? 1 : Math.random()<.7 ? 1.5 : 2.5;
    s.style.cssText = `
      left:${Math.random()*100}%;top:${Math.random()*100}%;
      width:${size}px;height:${size}px;
      --d:${2+Math.random()*4}s;
      --del:${Math.random()*4}s;
      --op:${.3+Math.random()*.7};
    `;
    sf.appendChild(s);
  }
}

// ── KEYBOARD SHORTCUT ──────────────────────────────────
document.addEventListener('keydown', e=>{
  if (e.key==='Escape') closeModal();
  if (e.key==='Delete' || e.key==='Backspace') clearCanvas();
});

// ── BOOT ───────────────────────────────────────────────
buildStarfield();
initGame('normal');
</script>
